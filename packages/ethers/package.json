{
  "name": "@ankr.com/vrpc-ethers",
  "version": "0.1.0",
  "type": "module",
  "description": "ethers v6 drop-in for Ankr's verifiable RPC — VrpcProvider verifies every JSON-RPC response (Ed25519) inside _send, fail-closed.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w3tech/verifiable-rpc-sdk.git",
    "directory": "packages/ethers"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ankr.com/dstack-verify": "workspace:*",
    "@ankr.com/vrpc-core": "workspace:*"
  },
  "peerDependencies": {
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@noble/ed25519": "^3.1.0",
    "@types/node": "*",
    "ethers": "^6.16.0"
  }
}
