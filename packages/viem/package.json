{
  "name": "@ankr.com/vrpc-viem",
  "version": "0.1.0",
  "type": "module",
  "description": "viem drop-in for Ankr's verifiable RPC — vrpcHttp custom transport verifies every JSON-RPC response (Ed25519) before parse, fail-closed.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ankr.com/dstack-verify": "workspace:*",
    "@ankr.com/vrpc-core": "workspace:*"
  },
  "peerDependencies": {
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@noble/ed25519": "^3.1.0",
    "viem": "^2.52.2"
  }
}
