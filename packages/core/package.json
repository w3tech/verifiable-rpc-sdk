{
  "name": "@w3tech.io/vrpc-core",
  "version": "0.3.0",
  "type": "module",
  "description": "Transport-agnostic Ed25519 verification primitives for Ankr's verifiable RPC — pre-image, signature verify, attestation.",
  "license": "Apache-2.0",
  "author": "Web3 Technologies, Inc.",
  "homepage": "https://github.com/w3tech/verifiable-rpc-sdk#readme",
  "bugs": "https://github.com/w3tech/verifiable-rpc-sdk/issues",
  "keywords": [
    "ethereum",
    "rpc",
    "verifiable",
    "attestation",
    "tdx",
    "ed25519",
    "json-rpc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w3tech/verifiable-rpc-sdk.git",
    "directory": "packages/core"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js",
        "default": "./dist/errors.js"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "prepublishOnly": "tsup && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:unit": "vitest run tests --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@w3tech.io/dstack-verify": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "lru-cache": "^11.5.1"
  },
  "devDependencies": {
    "@types/node": "*"
  }
}
