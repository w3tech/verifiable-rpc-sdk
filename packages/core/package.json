{
  "name": "@ankr.com/vrpc-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Transport-agnostic Ed25519 verification primitives for Ankr's verifiable RPC — pre-image, signature verify, attestation, compose.",
  "license": "Apache-2.0",
  "author": "Web3 Technologies, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w3tech/verifiable-rpc-sdk.git",
    "directory": "packages/core"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./compose": {
      "types": "./src/compose.ts",
      "import": "./dist/compose.js",
      "default": "./dist/compose.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js",
        "default": "./dist/errors.js"
      },
      "./compose": {
        "types": "./dist/compose.d.ts",
        "import": "./dist/compose.js",
        "default": "./dist/compose.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run tests --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ankr.com/dstack-verify": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "*"
  }
}
