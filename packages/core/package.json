{
  "name": "@ankr.com/vrpc-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Transport-agnostic Ed25519 verification primitives for Ankr's verifiable RPC — pre-image, signature verify, attestation, compose.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "bun": "./src/errors.ts",
      "types": "./src/errors.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js",
        "default": "./dist/errors.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "bun test",
    "test:unit": "bun test tests/*.test.ts",
    "test:integration": "bun test tests/integration/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ankr.com/dstack-verify": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "*"
  }
}
