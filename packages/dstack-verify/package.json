{
  "name": "@ankr.com/dstack-verify",
  "version": "0.1.0",
  "type": "module",
  "description": "Frozen contract for dstack/TDX attestation verification — currently a mock gate; real DCAP/RTMR verification is deferred to a future release.",
  "license": "Apache-2.0",
  "author": "Web3 Technologies, Inc.",
  "homepage": "https://github.com/w3tech/verifiable-rpc-sdk#readme",
  "bugs": "https://github.com/w3tech/verifiable-rpc-sdk/issues",
  "keywords": [
    "ethereum",
    "rpc",
    "verifiable",
    "attestation",
    "tdx",
    "dstack",
    "ed25519"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w3tech/verifiable-rpc-sdk.git",
    "directory": "packages/dstack-verify"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "*"
  }
}
