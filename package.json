{
  "name": "@ankr/verifiable-rpc-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript verifier client for Ankr's verifiable RPC sidecar — Ed25519 signature verification + TDX attestation helper.",
  "repository": {
    "type": "git",
    "url": "https://github.com/w3tech/verifiable-rpc-sdk.git"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "echo 'no build in Phase 18 — bundle in a later phase'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
