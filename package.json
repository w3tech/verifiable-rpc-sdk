{
  "name": "verifiable-rpc-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript verifier client for Ankr's verifiable RPC sidecar — Ed25519 signature verification + TDX attestation helper.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/w3tech/verifiable-rpc-sdk.git"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "example:01-signed-call": "tsx examples/01-signed-call.ts",
    "example:02-batch-and-replay": "tsx examples/02-batch-and-replay.ts",
    "example:03-fetch-attestation": "tsx examples/03-fetch-attestation.ts",
    "example:04-end-to-end": "tsx examples/04-end-to-end.ts",
    "example:05-gzip-transport": "tsx examples/05-gzip-transport.ts",
    "example:06-via-shark": "tsx examples/06-via-shark.ts",
    "example:07-attestation-via-shark": "tsx examples/07-attestation-via-shark.ts",
    "example:08-vrpc-ethers-verified-read": "tsx examples/08-vrpc-ethers-verified-read.ts",
    "example:09-vrpc-viem-verified-read": "tsx examples/09-vrpc-viem-verified-read.ts",
    "example:10-vrpc-lazy-attestation": "tsx examples/10-vrpc-lazy-attestation.ts",
    "example:all": "pnpm example:01-signed-call && pnpm example:02-batch-and-replay && pnpm example:03-fetch-attestation && pnpm example:04-end-to-end && pnpm example:05-gzip-transport && pnpm example:06-via-shark && pnpm example:07-attestation-via-shark && pnpm example:08-vrpc-ethers-verified-read && pnpm example:09-vrpc-viem-verified-read && pnpm example:10-vrpc-lazy-attestation"
  },
  "devDependencies": {
    "@ankr.com/dstack-verify": "workspace:*",
    "@ankr.com/vrpc-core": "workspace:*",
    "@ankr.com/vrpc-ethers": "workspace:*",
    "@ankr.com/vrpc-viem": "workspace:*",
    "@biomejs/biome": "^2.0.0",
    "@noble/ed25519": "^3.1.0",
    "ethers": "^6.16.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "viem": "^2.52.2"
  }
}
