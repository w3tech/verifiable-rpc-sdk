{
  "name": "@ankr/verifiable-rpc-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript verifier client for Ankr's verifiable RPC sidecar — Ed25519 signature verification + TDX attestation helper.",
  "repository": {
    "type": "git",
    "url": "https://github.com/w3tech/verifiable-rpc-sdk.git"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/*.test.ts",
    "test:integration": "bun test tests/integration/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "echo 'no build step yet — bundling deferred'",
    "example:01-signed-call": "bun run examples/01-signed-call.ts",
    "example:02-batch-and-replay": "bun run examples/02-batch-and-replay.ts",
    "example:03-fetch-attestation": "bun run examples/03-fetch-attestation.ts",
    "example:04-end-to-end": "bun run examples/04-end-to-end.ts",
    "example:05-gzip-transport": "bun run examples/05-gzip-transport.ts",
    "example:06-via-shark": "bun run examples/06-via-shark.ts",
    "example:all": "bun run example:01-signed-call && bun run example:02-batch-and-replay && bun run example:03-fetch-attestation && bun run example:04-end-to-end && bun run example:05-gzip-transport && bun run example:06-via-shark"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
